[gd_resource type="Resource" script_class="DialogueData" load_steps=2 format=3]

[ext_resource type="Script" path="res://resources/dialogue_data.gd" id="1"]

[resource]
script = ExtResource("1")
id = "mr_oak_dialogue"
nodes = {
	"greet": {
		"text": "Welcome to Pelican Town School. Class runs weekdays 8am to 2pm. Attend regularly and you'll earn a diploma, then a degree.",
		"choices": [
			{"text": "Attend today's class.", "next": "attended", "action": "school.attend"},
			{"text": "What can I unlock?", "next": "info"},
			{"text": "Goodbye.", "next": "farewell"}
		]
	},
	"attended": {
		"text": "Good work. Come back tomorrow for more.",
		"choices": [
			{"text": "Goodbye.", "next": "farewell"}
		]
	},
	"info": {
		"text": "A diploma lets you apply for skilled jobs. A degree unlocks the doctor's position.",
		"choices": [
			{"text": "Attend today's class.", "next": "attended", "action": "school.attend"},
			{"text": "Goodbye.", "next": "farewell"}
		]
	},
	"farewell": {
		"text": "Study well, neighbour.",
		"choices": []
	}
}
